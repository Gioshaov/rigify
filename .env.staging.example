# =====================================================================
# Rigify — STAGING environment variables
# =====================================================================
# These belong in Vercel, scoped to the `staging` branch (Preview).
# DO NOT put these in production. DO NOT commit real values.
# See STAGING.md for the full setup runbook.
# =====================================================================

# --- Supabase (SEPARATE staging project — never the production project) ---
# From the STAGING project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<staging-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App config ---
NEXT_PUBLIC_APP_URL=https://staging.rigify.ge
NEXT_PUBLIC_DEFAULT_LOCALE=ka
NEXT_PUBLIC_ROOT_DOMAIN=staging.rigify.ge

# --- Staging access gate (REQUIRED on staging, FORBIDDEN on production) ---
# Locks the whole site behind /password. Setting this on production would
# lock out all real visitors — gate is in the root middleware.ts.
SITE_PASSWORD=choose-a-staging-password

# Optional: gate the admin. subdomain behind a separate password on staging.
# ADMIN_PREVIEW_PASSWORD=choose-an-admin-password

# --- Shared services (safe to reuse the same tokens as production) ---
NEXT_PUBLIC_MAPBOX_TOKEN=

# Resend — reuse is fine, but emails sent from staging are real emails.
# Consider a test API key or a sandbox sender to avoid confusing recipients.
RESEND_API_KEY=

# Vapi — voice agent (not active yet)
VAPI_API_KEY=

# Supabase access token — only needed for local CLI work against staging,
# NOT required in the Vercel runtime.
# SUPABASE_ACCESS_TOKEN=
