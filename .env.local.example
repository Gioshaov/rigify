# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Access Token (optional) — for CLI operations
# Get from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ka
NEXT_PUBLIC_ROOT_DOMAIN=rigify.ge

# Vapi — for Salome voice agent management (Phase 4, optional for now)
VAPI_API_KEY=

# Mapbox — for map tiles and geocoding
# Get from: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=
